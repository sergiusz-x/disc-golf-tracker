# Supabase – from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Optionally leave for compatibility if you have an older setup:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key

# Application URL – in development keep http://localhost:3000.
# On Vercel set to https://your-domain.pl (or leave empty,
# the code falls back to VERCEL_URL).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local Supabase CLI Google OAuth provider only.
# Do not expose these in client code. In hosted Supabase, configure them in
# Dashboard → Authentication → Providers → Google instead of Vercel envs.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
